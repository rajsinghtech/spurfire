# Copy to .env and fill in. Tailscale OAuth client credentials
# (Tailscale admin console -> Settings -> OAuth clients).
TS_CLIENT_ID=
TS_CLIENT_SECRET=
TS_API_BASE=https://api.tailscale.com/api/v2

# Optional spurfire-server settings. Leave commented for defaults.
# SPURFIRE_BIND_ADDR=127.0.0.1:8080
# SPURFIRE_DRY_RUN=1
# SPURFIRE_DRY_RUN_TTL_SECS=300
# SPURFIRE_MAX_PLAYERS=16
# SPURFIRE_PROVISIONING_MODE=shared_tailnet
# SPURFIRE_SHARED_TAILNET=-
# SPURFIRE_STATE_PATH=.spurfire/server-state.json
