# Copy to .env and fill in. Tailscale OAuth client credentials
# (Tailscale admin console -> Settings -> OAuth clients).
TS_CLIENT_ID=
TS_CLIENT_SECRET=
TS_API_BASE=https://api.tailscale.com/api/v2

# Optional spurfire-server settings. Leave commented for defaults.
# SPURFIRE_BIND_ADDR=127.0.0.1:8080
# SPURFIRE_DRY_RUN=1
# Independent kill switch. Keep 0 until capability authorization, encrypted
# dynamic child-credential recovery, and startup reconciliation are approved.
# SPURFIRE_REAL_MUTATIONS_ENABLED=0
# Alpha hard cap shared by dedicated and shared-compatibility real lobbies.
# SPURFIRE_MAX_ACTIVE_REAL_LOBBIES=1
# SPURFIRE_DRY_RUN_TTL_SECS=300
# SPURFIRE_MAX_PLAYERS=16
# Provisioning mode: dry_run, tailnet_per_lobby (preferred dedicated isolation),
# or shared_tailnet (separately labeled compatibility mode).
# SPURFIRE_PROVISIONING_MODE=dry_run
# SPURFIRE_SHARED_TAILNET=-
# SPURFIRE_STATE_PATH=.spurfire/server-state.json

# Cached one-lobby network-summary contract. Background collectors use these
# intervals; inspection GETs must remain pure cached reads.
# SPURFIRE_NETWORK_DEVICE_INVENTORY_REFRESH_SECS=15
# SPURFIRE_NETWORK_DEVICE_INVENTORY_FRESH_FOR_SECS=30
# SPURFIRE_NETWORK_ORGANIZATION_PRESENCE_REFRESH_SECS=60
# SPURFIRE_NETWORK_ORGANIZATION_PRESENCE_FRESH_FOR_SECS=120
# SPURFIRE_NETWORK_PARTICIPANT_REPORT_FRESH_FOR_SECS=15
# SPURFIRE_NETWORK_PARTICIPANT_REPORT_RETENTION_SECS=60
