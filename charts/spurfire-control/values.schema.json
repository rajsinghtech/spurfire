{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "spurfire-control values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "image",
    "serviceAccount",
    "config",
    "networkSummary",
    "tailscale",
    "persistence",
    "service",
    "httpRoute",
    "resources",
    "childVault",
    "protectedAlpha"
  ],
  "properties": {
    "nameOverride": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "fullnameOverride": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "tag",
        "digest",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[0-9a-f]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "name",
        "annotations"
      ],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dryRun",
        "realMutationsEnabled",
        "maxActiveRealLobbies",
        "dryRunTtlSeconds",
        "maxPlayers",
        "provisioningMode",
        "sharedTailnet",
        "statePath",
        "realAdmissionEnabled",
        "allowLegacyClientAssertions",
        "trustForwardedFor",
        "childVaultPath"
      ],
      "properties": {
        "dryRun": {
          "type": "boolean"
        },
        "realMutationsEnabled": {
          "type": "boolean",
          "const": false
        },
        "maxActiveRealLobbies": {
          "type": "integer",
          "const": 1
        },
        "dryRunTtlSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "maxPlayers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "provisioningMode": {
          "type": "string",
          "enum": [
            "dry_run",
            "shared_tailnet",
            "tailnet_per_lobby"
          ]
        },
        "sharedTailnet": {
          "type": "string",
          "minLength": 1
        },
        "statePath": {
          "type": "string",
          "pattern": "^/var/lib/spurfire/[^/]+$"
        },
        "realAdmissionEnabled": {
          "type": "boolean",
          "const": false
        },
        "allowLegacyClientAssertions": {
          "type": "boolean",
          "const": false
        },
        "trustForwardedFor": {
          "type": "boolean"
        },
        "childVaultPath": {
          "type": "string",
          "pattern": "^/var/lib/spurfire/[^/]+$"
        }
      }
    },
    "networkSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deviceInventory",
        "organizationPresence",
        "participantReports"
      ],
      "properties": {
        "deviceInventory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "refreshSeconds",
            "freshForSeconds"
          ],
          "properties": {
            "refreshSeconds": {
              "type": "integer",
              "const": 15
            },
            "freshForSeconds": {
              "type": "integer",
              "const": 30
            }
          }
        },
        "organizationPresence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "refreshSeconds",
            "freshForSeconds"
          ],
          "properties": {
            "refreshSeconds": {
              "type": "integer",
              "const": 60
            },
            "freshForSeconds": {
              "type": "integer",
              "const": 120
            }
          }
        },
        "participantReports": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "freshForSeconds",
            "retentionSeconds"
          ],
          "properties": {
            "freshForSeconds": {
              "type": "integer",
              "const": 15
            },
            "retentionSeconds": {
              "type": "integer",
              "const": 60
            }
          }
        }
      }
    },
    "tailscale": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apiBase",
        "existingSecret",
        "clientIdKey",
        "clientSecretKey"
      ],
      "properties": {
        "apiBase": {
          "type": "string",
          "pattern": "^https://\\S+$"
        },
        "existingSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "clientIdKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "clientSecretKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "existingClaim",
        "storageClass",
        "accessModes",
        "size",
        "retain",
        "annotations"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingClaim": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "storageClass": {
          "type": "string"
        },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "ReadWriteOnce",
              "ReadOnlyMany",
              "ReadWriteMany",
              "ReadWriteOncePod"
            ]
          }
        },
        "size": {
          "type": "string",
          "pattern": "^[1-9][0-9]*(Ei|Pi|Ti|Gi|Mi|Ki)$"
        },
        "retain": {
          "type": "boolean"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotations",
        "port"
      ],
      "properties": {
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "annotations",
        "parentRefs",
        "hostnames",
        "path"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "parentRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "group": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "namespace": {
                "type": "string",
                "minLength": 1
              },
              "sectionName": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            }
          }
        },
        "hostnames": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253
          }
        },
        "path": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "Exact",
                "PathPrefix",
                "RegularExpression"
              ]
            },
            "value": {
              "type": "string",
              "pattern": "^/"
            }
          }
        }
      }
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceMap"
        },
        "requests": {
          "$ref": "#/definitions/resourceMap"
        }
      }
    },
    "nodeSelector": {
      "$ref": "#/definitions/stringMap"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "priorityClassName": {
      "type": "string"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 900
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "childVault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "existingSecret",
        "key",
        "mountPath"
      ],
      "properties": {
        "existingSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "key": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "mountPath": {
          "type": "string",
          "const": "/var/run/secrets/spurfire/vault.key"
        }
      }
    },
    "protectedAlpha": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "prepare",
        "installationId",
        "authorizedLobbyId",
        "publicOrigin",
        "internalListener",
        "sourceSha",
        "provenanceSha256",
        "artifactSetSha256",
        "policyProfileSha256",
        "leaseName",
        "runtimeImageDigest",
        "brokerImageDigest",
        "receiptSopsSecret",
        "receiptKey",
        "brokerCredentialSopsSecret",
        "credentialKey",
        "brokerVaultKeySopsSecret",
        "vaultKey",
        "runtimeTlsSecret",
        "brokerTlsSecret",
        "brokerMacSecret",
        "publicConfigMap",
        "brokerServicePort",
        "kubernetesApiServerCidrs"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "prepare": {
          "type": "boolean"
        },
        "installationId": {
          "type": "string",
          "pattern": "^$|^[A-Za-z0-9_-]{16,128}$"
        },
        "authorizedLobbyId": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "publicOrigin": {
          "type": "string",
          "pattern": "^$|^https://[^/]+$"
        },
        "internalListener": {
          "type": "string",
          "pattern": "^$|^[a-z0-9.-]+:9443$"
        },
        "sourceSha": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{40}$"
        },
        "provenanceSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "artifactSetSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "policyProfileSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "leaseName": {
          "type": "string",
          "const": "spurfire-protected-alpha"
        },
        "runtimeImageDigest": {
          "type": "string",
          "pattern": "^$|^sha256:[0-9a-f]{64}$"
        },
        "brokerImageDigest": {
          "type": "string",
          "pattern": "^$|^sha256:[0-9a-f]{64}$"
        },
        "receiptSopsSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "brokerCredentialSopsSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "brokerVaultKeySopsSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "runtimeTlsSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "brokerTlsSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "brokerMacSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "publicConfigMap": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "receiptKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "credentialKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "vaultKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "brokerServicePort": {
          "type": "integer",
          "const": 9443
        },
        "kubernetesApiServerCidrs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[0-9A-Fa-f:.]+/[0-9]{1,3}$"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "config": {
            "properties": {
              "dryRun": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "provisioningMode": {
                "const": "dry_run"
              }
            }
          },
          "tailscale": {
            "properties": {
              "existingSecret": {
                "const": ""
              }
            }
          },
          "childVault": {
            "properties": {
              "existingSecret": {
                "const": ""
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "config": {
            "properties": {
              "provisioningMode": {
                "enum": [
                  "shared_tailnet",
                  "tailnet_per_lobby"
                ]
              }
            }
          },
          "persistence": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "httpRoute": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "allOf": [
          {
            "anyOf": [
              {
                "properties": {
                  "config": {
                    "properties": {
                      "dryRun": {
                        "const": true
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "protectedAlpha": {
                    "properties": {
                      "enabled": {
                        "const": true
                      }
                    }
                  }
                }
              }
            ]
          },
          {
            "properties": {
              "config": {
                "properties": {
                  "realMutationsEnabled": {
                    "const": false
                  },
                  "realAdmissionEnabled": {
                    "const": false
                  },
                  "allowLegacyClientAssertions": {
                    "const": false
                  }
                }
              },
              "httpRoute": {
                "properties": {
                  "parentRefs": {
                    "minItems": 1
                  },
                  "hostnames": {
                    "minItems": 1
                  }
                }
              }
            }
          }
        ]
      }
    }
  ],
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "resourceMap": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          }
        ]
      }
    }
  }
}
