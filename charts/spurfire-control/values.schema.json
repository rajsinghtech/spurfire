{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "spurfire-control values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "image",
    "serviceAccount",
    "config",
    "networkSummary",
    "tailscale",
    "persistence",
    "service",
    "httpRoute",
    "resources"
  ],
  "properties": {
    "nameOverride": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "fullnameOverride": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[0-9a-f]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "annotations"],
      "properties": {
        "create": {"type": "boolean"},
        "name": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "annotations": {"$ref": "#/definitions/stringMap"}
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dryRun",
        "realMutationsEnabled",
        "maxActiveRealLobbies",
        "dryRunTtlSeconds",
        "maxPlayers",
        "provisioningMode",
        "sharedTailnet",
        "statePath"
      ],
      "properties": {
        "dryRun": {"type": "boolean"},
        "realMutationsEnabled": {"type": "boolean", "const": false},
        "maxActiveRealLobbies": {
          "type": "integer",
          "const": 1
        },
        "dryRunTtlSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "maxPlayers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "provisioningMode": {
          "type": "string",
          "enum": ["dry_run", "shared_tailnet", "tailnet_per_lobby"]
        },
        "sharedTailnet": {
          "type": "string",
          "minLength": 1
        },
        "statePath": {
          "type": "string",
          "pattern": "^/var/lib/spurfire/[^/]+$"
        }
      }
    },
    "networkSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deviceInventory", "organizationPresence", "participantReports"],
      "properties": {
        "deviceInventory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["refreshSeconds", "freshForSeconds"],
          "properties": {
            "refreshSeconds": {"type": "integer", "const": 15},
            "freshForSeconds": {"type": "integer", "const": 30}
          }
        },
        "organizationPresence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["refreshSeconds", "freshForSeconds"],
          "properties": {
            "refreshSeconds": {"type": "integer", "const": 60},
            "freshForSeconds": {"type": "integer", "const": 120}
          }
        },
        "participantReports": {
          "type": "object",
          "additionalProperties": false,
          "required": ["freshForSeconds", "retentionSeconds"],
          "properties": {
            "freshForSeconds": {"type": "integer", "const": 15},
            "retentionSeconds": {"type": "integer", "const": 60}
          }
        }
      }
    },
    "tailscale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiBase", "existingSecret", "clientIdKey", "clientSecretKey"],
      "properties": {
        "apiBase": {
          "type": "string",
          "pattern": "^https://\\S+$"
        },
        "existingSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "clientIdKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "clientSecretKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "existingClaim",
        "storageClass",
        "accessModes",
        "size",
        "retain",
        "annotations"
      ],
      "properties": {
        "enabled": {"type": "boolean"},
        "existingClaim": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "storageClass": {"type": "string"},
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
          }
        },
        "size": {
          "type": "string",
          "pattern": "^[1-9][0-9]*(Ei|Pi|Ti|Gi|Mi|Ki)$"
        },
        "retain": {"type": "boolean"},
        "annotations": {"$ref": "#/definitions/stringMap"}
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["annotations", "port"],
      "properties": {
        "annotations": {"$ref": "#/definitions/stringMap"},
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "annotations", "parentRefs", "hostnames", "path"],
      "properties": {
        "enabled": {"type": "boolean"},
        "annotations": {"$ref": "#/definitions/stringMap"},
        "parentRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "group": {"type": "string"},
              "kind": {"type": "string"},
              "name": {"type": "string", "minLength": 1},
              "namespace": {"type": "string", "minLength": 1},
              "sectionName": {"type": "string", "minLength": 1},
              "port": {"type": "integer", "minimum": 1, "maximum": 65535}
            }
          }
        },
        "hostnames": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253
          }
        },
        "path": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Exact", "PathPrefix", "RegularExpression"]
            },
            "value": {
              "type": "string",
              "pattern": "^/"
            }
          }
        }
      }
    },
    "podAnnotations": {"$ref": "#/definitions/stringMap"},
    "podLabels": {"$ref": "#/definitions/stringMap"},
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {"$ref": "#/definitions/resourceMap"},
        "requests": {"$ref": "#/definitions/resourceMap"}
      }
    },
    "nodeSelector": {"$ref": "#/definitions/stringMap"},
    "tolerations": {
      "type": "array",
      "items": {"type": "object"}
    },
    "affinity": {"type": "object"},
    "topologySpreadConstraints": {
      "type": "array",
      "items": {"type": "object"}
    },
    "priorityClassName": {"type": "string"},
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "config": {
            "properties": {
              "dryRun": {"const": true}
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "provisioningMode": {"const": "dry_run"}
            }
          },
          "tailscale": {
            "properties": {
              "existingSecret": {"const": ""}
            }
          }
        }
      },
      "else": {
        "properties": {
          "config": {
            "properties": {
              "provisioningMode": {
                "enum": ["shared_tailnet", "tailnet_per_lobby"]
              }
            }
          },
          "tailscale": {
            "properties": {
              "existingSecret": {"minLength": 1}
            }
          },
          "persistence": {
            "properties": {
              "enabled": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "httpRoute": {
            "properties": {
              "enabled": {"const": true}
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "dryRun": {"const": true},
              "realMutationsEnabled": {"const": false}
            }
          },
          "httpRoute": {
            "properties": {
              "parentRefs": {"minItems": 1},
              "hostnames": {"minItems": 1}
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "resourceMap": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {"type": "string"},
          {"type": "number"}
        ]
      }
    }
  }
}
